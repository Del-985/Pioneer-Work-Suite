{
  "name": "work-suite",
  "private": true,
  "version": "0.1.19",
  "packageManager": "pnpm@11.9.0",
  "workspaces": [
    "apps/*",
    "desktop"
  ],
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "dev:web": "pnpm --filter pioneer-student-web dev",
    "dev:api": "pnpm --filter pioneer-student-api dev",
    "dev:desktop": "pnpm --filter pioneer-work-suite-desktop tauri:dev",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "build:web": "pnpm --filter pioneer-student-web build",
    "build:api": "pnpm --filter pioneer-student-api build",
    "build:desktop": "pnpm --filter pioneer-work-suite-desktop tauri:build",
    "build:pioneeros": "make -C pioneeros",
    "package:pioneeros": "make -C pioneeros package",
    "test:api": "pnpm --filter pioneer-student-api test",
    "test:web": "pnpm --filter pioneer-student-web test",
    "test": "pnpm test:web && pnpm test:api",
    "check:architecture": "node scripts/check-maintainability.mjs",
    "ci:backend": "pnpm check:architecture && pnpm test && pnpm build:web",
    "build": "pnpm build:api && pnpm build:web && pnpm build:desktop"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
