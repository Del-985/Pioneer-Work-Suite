// apps/api/prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String
  createdAt    DateTime @default(now())

  tasks        Task[]
  documents    Document[]
  events       Event[]

  mailAccounts MailAccount[]
  mailMessages MailMessage[]
}

model Task {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String

  title       String
  description String   @default("")
  status      String
  priority    String   @default("medium")
  tags        String[] @default([])
  dueDate     DateTime?
  completedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, archivedAt, status])
}

model Document {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String

  title      String
  content    String   @default("")
  isPinned   Boolean  @default(false)
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, isPinned, updatedAt])
  @@index([userId, isFavorite])
}

model Event {
  id          String   @id @default(cuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  title       String
  description String?

  start       DateTime
  end         DateTime
  allDay      Boolean  @default(false)

  kind        String   @default("general")
  urgency     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, start])
}

model MailAccount {
  id        String   @id @default(cuid())

  user      User     @relation(fields: [userId], references: [id])
  userId    String

  provider     String
  emailAddress String
  displayName  String?

  imapHost   String
  imapPort   Int
  imapUseTLS Boolean @default(true)

  smtpHost   String
  smtpPort   Int
  smtpUseTLS Boolean @default(true)

  username    String
  passwordEnc String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages MailMessage[]
}

model MailMessage {
  id String @id @default(cuid())

  account   MailAccount @relation(fields: [accountId], references: [id])
  accountId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  externalId String?
  folder     String

  subject     String
  fromAddress String
  toAddress   String
  ccAddress   String?
  bccAddress  String?

  bodyHtml String @default("")
  bodyText String @default("")

  isRead    Boolean @default(false)
  isStarred Boolean @default(false)

  sentAt     DateTime?
  receivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  threadKey   String?
  inReplyToId String?
}
