NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pioneer_work_suite
JWT_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,tauri://localhost,https://tauri.localhost
JSON_BODY_LIMIT=2mb
SHUTDOWN_TIMEOUT_MS=10000

# Optional outbound SMTP. Internal Work Suite mail works without these.
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASS=
